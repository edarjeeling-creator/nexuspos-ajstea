# ==========================================
# NEXUSPOS AI - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and configure for local development
# Copy to Coolify for production deployment

# 1. SUPABASE HOSTED BACKEND
NEXT_PUBLIC_SUPABASE_URL=https://nexusposbase.gyanodayniketan.cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 2. APPLICATION CONFIGURATION
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000 # Use https://nexus.gyanodayniketan.cloud in production

# 3. OBSERVABILITY
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# 4. EXTERNAL INTEGRATIONS
STRIPE_SECRET_KEY=your_stripe_secret_key
WHATSAPP_API_TOKEN=your_whatsapp_token
ZOMATO_WEBHOOK_SECRET=your_zomato_secret
OPENAI_API_KEY=your_openai_api_key

# 5. COOLIFY / REDIS RATE LIMITING
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
