-- 8. SYSTEM & OUTLET SETTINGS
-- ------------------------------------------------------------------------------
CREATE TABLE IF NOT EXISTS public.system_settings (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    tenant_id UUID NOT NULL REFERENCES public.tenants(id) ON DELETE CASCADE,
    key VARCHAR(100) NOT NULL,
    value JSONB NOT NULL,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(tenant_id, key)
);
COMMENT ON TABLE public.system_settings IS 'Tenant-level configuration key-value pairs.';

CREATE INDEX IF NOT EXISTS idx_system_settings_tenant_id ON public.system_settings(tenant_id);

CREATE TRIGGER set_system_settings_updated_at
BEFORE UPDATE ON public.system_settings
