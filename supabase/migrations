CREATE TRIGGER audit_outlet_settings
AFTER INSERT OR UPDATE OR DELETE ON public.outlet_settings
FOR EACH ROW EXECUTE FUNCTION public.process_audit_log();

ALTER TABLE public.outlet_settings ENABLE ROW LEVEL SECURITY;

CREATE POLICY outlet_settings_isolation_policy ON public.outlet_settings
